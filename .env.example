# ── SuriaSnap Frontend — Environment Variables ────────────────────────────────
# Copy this file to .env (local dev) or set these in your Vercel project settings.
# Never commit .env to version control.
# All VITE_ variables are inlined at build time — they are public.

# ── API ───────────────────────────────────────────────────────────────────────
# Base URL of the backend API (no trailing slash).
# This must be set to your Render service URL before deploying to Vercel.
#
# Local development:
VITE_API_URL=http://localhost:8000
#
# Production (set this in Vercel Dashboard → Settings → Environment Variables):
# VITE_API_URL=https://suriasnap-backend.onrender.com
